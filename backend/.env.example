# ============================================================
# Penda Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Your dev Groq API key (used for Trial users) ---
GROQ_API_KEY=""

# --- Supabase Project Settings ---
# Found at: Supabase Dashboard > Settings > API
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# Anon/public key — safe for client-side use, used by auth.py for signup/login
# Found at: Supabase Dashboard > Settings > API > Project API keys > anon (public)
SUPABASE_ANON_KEY=""

# --- Supabase JWT Secret (for server-side token verification) ---
# Found at: Supabase Dashboard > Settings > API > JWT Settings
SUPABASE_JWT_SECRET=""

# --- CORS: comma-separated list of allowed frontend origins ---
# In development: http://localhost:3000
# In production: https://penda.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend URL (used for password-reset email redirect and share links) ---
# In development: http://localhost:3000
# In production: https://penda.vercel.app
FRONTEND_URL=http://localhost:3000

# --- BYOK encryption key (generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
BYOK_ENCRYPTION_KEY=""

# ============================================================
# V3 — New variables added for Storage, RAG, and ATS
# ============================================================

# --- Supabase Storage Buckets (create these in Supabase Dashboard > Storage) ---
# Bucket 1: "documents"   — private, max 50 MB, allowed: pdf, txt, docx, png, jpg
# Bucket 2: "ats-resumes" — private, max 20 MB, allowed: pdf, docx
# No env vars needed — bucket names are hardcoded in database.py as constants.

# --- OpenAI API Key (used for text-embedding-3-small embeddings for RAG) ---
# Only required if you want RAG/pgvector document search.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
