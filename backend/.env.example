# ============================================================
# Penda Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Your dev Groq API key (used for Trial users) ---
GROQ_API_KEY=""

# --- Supabase Project Settings ---
# Found at: Supabase Dashboard > Settings > API
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# Anon/public key — safe for client-side use, used by auth.py for signup/login
# Found at: Supabase Dashboard > Settings > API > Project API keys > anon (public)
SUPABASE_ANON_KEY=""

# --- Supabase JWT Secret (for server-side token verification) ---
# Found at: Supabase Dashboard > Settings > API > JWT Settings
SUPABASE_JWT_SECRET=""

# --- CORS: comma-separated list of allowed frontend origins ---
# In development: http://localhost:3000
# In production: https://penda.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend URL (used for password-reset email redirect) ---
# In development: http://localhost:3000
# In production: https://penda.vercel.app
FRONTEND_URL=http://localhost:3000
