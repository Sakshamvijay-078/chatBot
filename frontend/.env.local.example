# ============================================================
# Penda Frontend — Environment Variables
# Copy this file to .env.local and fill in real values.
# Variables prefixed with NEXT_PUBLIC_ are safe for the browser.
# ============================================================

# --- Supabase (public anon key — safe to expose) ---
# Found at: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- FastAPI backend URL ---
# Development: http://localhost:8000
# Production:  https://penda-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
